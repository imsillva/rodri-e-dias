// Read from serial port in non-canonical mode
//
// Modified by: Eduardo Nuno Almeida [enalmeida@fe.up.pt]

#include <fcntl.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/types.h>
#include <sys/stat.h>
#include <termios.h>
#include <unistd.h>

#define BAUDRATE B38400
#define _POSIX_SOURCE 1

#define FALSE 0
#define TRUE 1

#define BUF_SIZE 256
#define UA_SIZE 5

typedef enum {
    START,
    FLAG_READ,
    A_READ,
    C_READ,
    BCC_READ,
    DATA_READ,
    STOP_ME
} statenames;

void initME();
statenames currentState;

void initME() {
    currentState = START;
}

volatile int STOP = FALSE;

int main(int argc, char *argv[])
{
    initME();

    if (argc < 2)
    {
        printf("Incorrect program usage\n"
               "Usage: %s <SerialPort>\n"
               "Example: %s /dev/ttyS1\n",
               argv[0], argv[0]);
        exit(1);
    }

    const char *serialPortName = argv[1];

    int fd = open(serialPortName, O_RDWR | O_NOCTTY);
    if (fd < 0)
    {
        perror(serialPortName);
        exit(-1);
    }

    struct termios oldtio;
    struct termios newtio;

    if (tcgetattr(fd, &oldtio) == -1)
    {
        perror("tcgetattr");
        exit(-1);
    }

    memset(&newtio, 0, sizeof(newtio));

    newtio.c_cflag = BAUDRATE | CS8 | CLOCAL | CREAD;
    newtio.c_iflag = IGNPAR;
    newtio.c_oflag = 0;
    newtio.c_lflag = 0;

    // leitura byte a byte
    newtio.c_cc[VTIME] = 0;
    newtio.c_cc[VMIN] = 1;

    tcflush(fd, TCIOFLUSH);

    if (tcsetattr(fd, TCSANOW, &newtio) == -1)
    {
        perror("tcsetattr");
        exit(-1);
    }

    printf("New termios structure set\n");

    unsigned char buf = 0;
    int bytes_read;

    unsigned char data[BUF_SIZE] = {0};
    int i = 0;

    unsigned char BCC2_read = 0;
    unsigned char xor_read = 0;

    while (currentState != STOP_ME)
    {
        bytes_read = read(fd, &buf, 1);

        if (bytes_read < 0)
        {
            perror("read");
            break;
        }

        if (bytes_read == 0)
            continue;

        switch (currentState)
        {
            case START:

                if (buf == 0x7E) {
                    currentState = FLAG_READ;
                    printf("FLAG = 0x%02X\n", buf);
                } else {
                    currentState = START;
                }

            break;

            case FLAG_READ:

                if (buf == 0x03) {
                    currentState = A_READ;
                    printf("A = 0x%02X\n", buf);
                } else if (buf == 0x7E) {
                    currentState = FLAG_READ;
                } else {
                    currentState = START;
                }

            break;

            case A_READ:

                if (buf == 0x03) {
                    currentState = C_READ;
                    printf("C = 0x%02X\n", buf);
                } else if (buf == 0x7E) {
                    currentState = FLAG_READ;
                } else {
                    currentState = START;
                }

            break;

            case C_READ:

                if (buf == (0x03 ^ 0x03)) {
                    currentState = BCC_READ;
                    printf("BCC1 = 0x%02X\n", buf);
                } else if (buf == 0x7E) {
                    currentState = FLAG_READ;
                } else {
                    currentState = START;
                }

            break;

            case BCC_READ:

                // depois do BCC1 vem DATA, não FLAG
                if (buf == 0x7E) {
                    // trama inválida: terminou logo após BCC1
                    currentState = START;
                    i = 0;
                    xor_read = 0;
                } else {
                    data[0] = buf;
                    i = 1;
                    currentState = DATA_READ;
                }

            break;

            case DATA_READ:

                if (buf == 0x7E) {

                    // o último byte armazenado é o BCC2
                    if (i < 1) {
                        printf("Trama inválida: sem dados/BCC2\n");
                        currentState = START;
                        i = 0;
                        xor_read = 0;
                        break;
                    }

                    BCC2_read = data[i - 1];
                    xor_read = 0;

                    for (int j = 0; j < i - 1; j++) {
                        printf("valor da data: 0x%02X\n", data[j]);
                        xor_read ^= data[j];
                    }

                    printf("BCC2 lido: 0x%02X\n", BCC2_read);
                    printf("BCC2 calculado: 0x%02X\n", xor_read);

                    if (BCC2_read == xor_read) {
                        printf("Trama válida\n");
                        currentState = STOP_ME;
                    } else {
                        printf("Erro no BCC2\n");
                        currentState = START;
                        i = 0;
                        xor_read = 0;
                    }

                } else {

                    if (i >= BUF_SIZE) {
                        printf("Overflow no buffer de dados\n");
                        currentState = START;
                        i = 0;
                        xor_read = 0;
                    } else {
                        data[i] = buf;
                        i++;
                    }
                }

            break;

            case STOP_ME:
            break;
        }
    }

    // enviar UA
    if (currentState == STOP_ME) {
        unsigned char A = 0x01;
        unsigned char C = 0x07;
        unsigned char F = 0x7E;
        unsigned char BCC = A ^ C;
        unsigned char UA[UA_SIZE] = {F, A, C, BCC, F};

        int teste = write(fd, UA, UA_SIZE);

        if (teste < 0) {
            perror("write");
        } else {
            printf("UA enviada\n");
        }
    }

    sleep(1);

    if (tcsetattr(fd, TCSANOW, &oldtio) == -1)
    {
        perror("tcsetattr");
        exit(-1);
    }

    close(fd);

    return 0;
}
