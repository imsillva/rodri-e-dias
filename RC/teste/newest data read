// Read from serial port in non-canonical mode
//
// Modified by: Eduardo Nuno Almeida [enalmeida@fe.up.pt]

#include <fcntl.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/types.h>
#include <sys/stat.h>
#include <termios.h>
#include <unistd.h>

#define BAUDRATE B38400
#define _POSIX_SOURCE 1

#define FALSE 0
#define TRUE 1

#define MAX_DATA_SIZE 256
#define UA_SIZE 5

#define FLAG 0x7E
#define A_TX  0x03
#define C_TX  0x03
#define A_RX  0x01
#define C_UA  0x07

typedef enum {
    START,
    FLAG_READ,
    A_READ,
    C_READ,
    BCC1_READ,
    DATA_READ,
    STOP_ME
} statenames;

statenames currentState;

void initME()
{
    currentState = START;
}

volatile int STOP = FALSE;

int main(int argc, char *argv[])
{
    initME();

    if (argc < 2)
    {
        printf("Incorrect program usage\n"
               "Usage: %s <SerialPort>\n"
               "Example: %s /dev/ttyS1\n",
               argv[0], argv[0]);
        exit(1);
    }

    const char *serialPortName = argv[1];

    int fd = open(serialPortName, O_RDWR | O_NOCTTY);
    if (fd < 0)
    {
        perror(serialPortName);
        exit(-1);
    }

    struct termios oldtio;
    struct termios newtio;

    if (tcgetattr(fd, &oldtio) == -1)
    {
        perror("tcgetattr");
        exit(-1);
    }

    memset(&newtio, 0, sizeof(newtio));

    newtio.c_cflag = BAUDRATE | CS8 | CLOCAL | CREAD;
    newtio.c_iflag = IGNPAR;
    newtio.c_oflag = 0;
    newtio.c_lflag = 0;

    // byte a byte
    newtio.c_cc[VTIME] = 0;
    newtio.c_cc[VMIN] = 1;

    tcflush(fd, TCIOFLUSH);

    if (tcsetattr(fd, TCSANOW, &newtio) == -1)
    {
        perror("tcsetattr");
        exit(-1);
    }

    printf("New termios structure set\n");

    unsigned char byte = 0;
    int bytes_read = 0;

    unsigned char data[MAX_DATA_SIZE] = {0};
    int data_index = 0;

    unsigned char A = 0;
    unsigned char C = 0;

    while (1)
    {
        bytes_read = read(fd, &byte, 1);

        if (bytes_read < 0)
        {
            perror("read");
            break;
        }

        if (bytes_read == 0)
            continue;

        switch (currentState)
        {
            case START:
                if (byte == FLAG)
                {
                    currentState = FLAG_READ;
                    printf("FLAG = 0x%02X\n", byte);
                }
                break;

            case FLAG_READ:
                if (byte == FLAG)
                {
                    currentState = FLAG_READ;
                }
                else if (byte == A_TX)
                {
                    A = byte;
                    currentState = A_READ;
                    printf("A = 0x%02X\n", byte);
                }
                else
                {
                    currentState = START;
                }
                break;

            case A_READ:
                if (byte == FLAG)
                {
                    currentState = FLAG_READ;
                }
                else if (byte == C_TX)
                {
                    C = byte;
                    currentState = C_READ;
                    printf("C = 0x%02X\n", byte);
                }
                else
                {
                    currentState = START;
                }
                break;

            case C_READ:
                if (byte == FLAG)
                {
                    currentState = FLAG_READ;
                }
                else if (byte == (A ^ C))
                {
                    currentState = BCC1_READ;
                    printf("BCC1 = 0x%02X\n", byte);
                }
                else
                {
                    currentState = START;
                }
                break;

            case BCC1_READ:
                // depois de BCC1 começa a zona DATA + BCC2
                if (byte == FLAG)
                {
                    // trama inválida
                    currentState = START;
                    data_index = 0;
                }
                else
                {
                    data[0] = byte;
                    data_index = 1;
                    currentState = DATA_READ;
                }
                break;

            case DATA_READ:
                if (byte == FLAG)
                {
                    if (data_index < 1)
                    {
                        printf("Erro: trama demasiado curta\n");
                        currentState = START;
                        data_index = 0;
                        break;
                    }

                    unsigned char bcc2_read = data[data_index - 1];
                    unsigned char bcc2_calc = 0x00;

                    printf("Data bytes:\n");
                    for (int i = 0; i < data_index - 1; i++)
                    {
                        printf("data[%d] = 0x%02X\n", i, data[i]);
                        bcc2_calc ^= data[i];
                    }

                    printf("BCC2 lido      = 0x%02X\n", bcc2_read);
                    printf("BCC2 calculado = 0x%02X\n", bcc2_calc);

                    if (bcc2_read == bcc2_calc)
                    {
                        printf("Trama valida\n");

                        unsigned char UA[UA_SIZE];
                        UA[0] = FLAG;
                        UA[1] = A_RX;
                        UA[2] = C_UA;
                        UA[3] = UA[1] ^ UA[2];
                        UA[4] = FLAG;

                        int res = write(fd, UA, UA_SIZE);
                        if (res < 0)
                            perror("write");
                        else
                            printf("UA enviada\n");
                    }
                    else
                    {
                        printf("Erro no BCC2 - trama rejeitada\n");
                    }

                    // reiniciar sempre para esperar nova trama
                    currentState = START;
                    data_index = 0;
                }
                else
                {
                    if (data_index >= MAX_DATA_SIZE)
                    {
                        printf("Overflow no buffer\n");
                        currentState = START;
                        data_index = 0;
                    }
                    else
                    {
                        data[data_index] = byte;
                        data_index++;
                    }
                }
                break;

            case STOP_ME:
                currentState = START;
                break;
        }
    }

    sleep(1);

    if (tcsetattr(fd, TCSANOW, &oldtio) == -1)
    {
        perror("tcsetattr");
        exit(-1);
    }

    close(fd);
    return 0;
}
