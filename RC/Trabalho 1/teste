// Read from serial port in non-canonical mode — Data Link Layer Receiver

#include <fcntl.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/types.h>
#include <sys/stat.h>
#include <termios.h>
#include <unistd.h>

#define BAUDRATE B38400
#define _POSIX_SOURCE 1

#define FALSE 0
#define TRUE 1

#define MAX_DATA_SIZE 256
#define SU_FRAME_SIZE 5

#define FLAG   0x7E
#define A_TX   0x03   // endereço: comandos do transmissor
#define A_RX   0x03   // endereço: respostas do recetor (mesmo valor!)

// Bytes de controlo
#define C_SET  0x03   // SET (ligação)
#define C_UA   0x07   // UA (unnumbered acknowledgement)
#define C_I0   0x00   // I-frame, sequência 0
#define C_I1   0x40   // I-frame, sequência 1
#define C_RR0  0x05   // RR, Nr=0 (espera frame 0)
#define C_RR1  0x85   // RR, Nr=1 (espera frame 1)
#define C_REJ0 0x01   // REJ, Nr=0
#define C_REJ1 0x81   // REJ, Nr=1

typedef enum {
    START,
    FLAG_READ,
    A_READ,
    C_READ,
    BCC1_READ,
    DATA_READ,
    STOP_ME
} statenames;

// Estado da ligação (separado da máquina de estados da trama)
typedef enum {
    DISCONNECTED,
    CONNECTED
} connState_t;

statenames currentState;
connState_t connState;

void initME() {
    currentState = START;
    connState    = DISCONNECTED;
}

int main(int argc, char *argv[]) {
    initME();

    if (argc < 2) {
        printf("Usage: %s <SerialPort>\n"
               "Example: %s /dev/ttyS1\n", argv[0], argv[0]);
        exit(1);
    }

    const char *serialPortName = argv[1];

    int fd = open(serialPortName, O_RDWR | O_NOCTTY);
    if (fd < 0) { perror(serialPortName); exit(-1); }

    struct termios oldtio, newtio;
    if (tcgetattr(fd, &oldtio) == -1) { perror("tcgetattr"); exit(-1); }

    memset(&newtio, 0, sizeof(newtio));
    newtio.c_cflag = BAUDRATE | CS8 | CLOCAL | CREAD;
    newtio.c_iflag = IGNPAR;
    newtio.c_oflag = 0;
    newtio.c_lflag = 0;
    newtio.c_cc[VTIME] = 0;
    newtio.c_cc[VMIN]  = 1;

    tcflush(fd, TCIOFLUSH);
    if (tcsetattr(fd, TCSANOW, &newtio) == -1) { perror("tcsetattr"); exit(-1); }

    printf("New termios structure set\n");

    unsigned char byte = 0;
    int bytes_read = 0;

    unsigned char data[MAX_DATA_SIZE] = {0};
    int data_index = 0;

    unsigned char A = 0, C = 0;
    int expectedSeq = 0;  // número de sequência esperado: 0 ou 1

    while (1) {
        bytes_read = read(fd, &byte, 1);
        if (bytes_read < 0) { perror("read"); break; }
        if (bytes_read == 0) continue;

        switch (currentState) {

            case START:
                if (byte == FLAG) {
                    currentState = FLAG_READ;
                    printf("FLAG = 0x%02X\n", byte);
                }
                break;

            case FLAG_READ:
                if (byte == FLAG) {
                    // FLAG repetido: mantém estado
                } else if (byte == A_TX) {
                    A = byte;
                    currentState = A_READ;
                    printf("A = 0x%02X\n", byte);
                } else {
                    currentState = START;
                }
                break;

            case A_READ:
                if (byte == FLAG) {
                    currentState = FLAG_READ;
                } else if (connState == DISCONNECTED && byte == C_SET) {
                    // Fase de ligação: aceita SET
                    C = byte;
                    currentState = C_READ;
                    printf("C = 0x%02X (SET)\n", byte);
                } else if (connState == CONNECTED &&
                           (byte == C_I0 || byte == C_I1)) {
                    // Fase de dados: aceita I-frames
                    C = byte;
                    currentState = C_READ;
                    printf("C = 0x%02X (I-frame seq=%d)\n", byte,
                           (byte == C_I0) ? 0 : 1);
                } else {
                    currentState = START;
                }
                break;

            case C_READ:
                if (byte == FLAG) {
                    currentState = FLAG_READ;
                } else if (byte == (A ^ C)) {
                    currentState = BCC1_READ;
                    printf("BCC1 = 0x%02X\n", byte);
                } else {
                    currentState = START;
                }
                break;

            case BCC1_READ:
                if (byte == FLAG) {
                    // FLAG aqui => trama de supervisão/unnumbered sem dados
                    if (connState == DISCONNECTED && C == C_SET) {
                        printf("SET recebido com sucesso\n");

                        // Envia UA em resposta ao SET
                        unsigned char UA[SU_FRAME_SIZE];
                        UA[0] = FLAG;
                        UA[1] = A_RX;
                        UA[2] = C_UA;
                        UA[3] = UA[1] ^ UA[2];  // BCC1 = A ^ C
                        UA[4] = FLAG;

                        int res = write(fd, UA, SU_FRAME_SIZE);
                        if (res < 0) perror("write");
                        else {
                            printf("UA enviada\n");
                            connState = CONNECTED;   // ligação estabelecida
                            printf("Ligação estabelecida. À espera de I-frames...\n");
                        }
                    }
                    currentState = START;
                    data_index = 0;
                } else {
                    // Byte de dados de uma I-frame
                    data[0] = byte;
                    data_index = 1;
                    currentState = DATA_READ;
                }
                break;

            case DATA_READ:
                if (byte == FLAG) {
                    if (data_index < 1) {
                        printf("Erro: trama demasiado curta\n");
                        currentState = START;
                        data_index = 0;
                        break;
                    }

                    // Último byte recebido antes de FLAG é o BCC2
                    unsigned char bcc2_read = data[data_index - 1];
                    unsigned char bcc2_calc = 0x00;

                    printf("Data bytes:\n");
                    for (int i = 0; i < data_index - 1; i++) {
                        printf("  data[%d] = 0x%02X\n", i, data[i]);
                        bcc2_calc ^= data[i];
                    }

                    printf("BCC2 lido      = 0x%02X\n", bcc2_read);
                    printf("BCC2 calculado = 0x%02X\n", bcc2_calc);

                    int frameSeq = (C == C_I0) ? 0 : 1;

                    if (bcc2_read == bcc2_calc) {
                        if (frameSeq == expectedSeq) {
                            // Trama nova e válida
                            printf("I-frame %d válida\n", frameSeq);
                            expectedSeq = 1 - expectedSeq;  // alterna 0 <-> 1

                            // Envia RR a indicar o próximo frame esperado
                            unsigned char RR[SU_FRAME_SIZE];
                            RR[0] = FLAG;
                            RR[1] = A_RX;
                            RR[2] = (expectedSeq == 0) ? C_RR0 : C_RR1;
                            RR[3] = RR[1] ^ RR[2];
                            RR[4] = FLAG;

                            int res = write(fd, RR, SU_FRAME_SIZE);
                            if (res < 0) perror("write");
                            else printf("RR%d enviado\n", expectedSeq);

                        } else {
                            // Trama duplicada (já recebida): reenvia RR anterior
                            printf("I-frame duplicada (seq=%d, esperado=%d) — ignorada\n",
                                   frameSeq, expectedSeq);

                            unsigned char RR[SU_FRAME_SIZE];
                            RR[0] = FLAG;
                            RR[1] = A_RX;
                            RR[2] = (expectedSeq == 0) ? C_RR0 : C_RR1;
                            RR[3] = RR[1] ^ RR[2];
                            RR[4] = FLAG;
                            write(fd, RR, SU_FRAME_SIZE);
                        }
                    } else {
                        // BCC2 errado: envia REJ
                        printf("Erro no BCC2 — trama rejeitada\n");

                        unsigned char REJ[SU_FRAME_SIZE];
                        REJ[0] = FLAG;
                        REJ[1] = A_RX;
                        REJ[2] = (expectedSeq == 0) ? C_REJ0 : C_REJ1;
                        REJ[3] = REJ[1] ^ REJ[2];
                        REJ[4] = FLAG;

                        int res = write(fd, REJ, SU_FRAME_SIZE);
                        if (res < 0) perror("write");
                        else printf("REJ%d enviado\n", expectedSeq);
                    }

                    currentState = START;
                    data_index = 0;

                } else {
                    if (data_index >= MAX_DATA_SIZE) {
                        printf("Overflow no buffer\n");
                        currentState = START;
                        data_index = 0;
                    } else {
                        data[data_index++] = byte;
                    }
                }
                break;

            case STOP_ME:
                currentState = START;
                break;
        }
    }

    sleep(1);
    if (tcsetattr(fd, TCSANOW, &oldtio) == -1) { perror("tcsetattr"); exit(-1); }
    close(fd);
    return 0;
}
